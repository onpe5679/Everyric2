# everyric2 서버 설정 템플릿 — 리포 루트에 .env 로 복사해서 채운다
#   cp deploy/.env.example .env
# systemd EnvironmentFile로도 읽히므로 KEY=value 형식 유지 (값에 공백·따옴표 금지)

# ── 필수: API 키 (외부 노출 배포) ────────────────────────────────
# 생성: openssl rand -hex 32
# 설정하면 /api 전체가 X-API-Key 헤더를 요구한다 (확장 옵션의 API 키 칸에 같은 값 입력)
EVERYRIC_SERVER_API_KEY=
# 어드민 키(선택): 설정하면 일반 키의 파괴적 행위(강제 재생성·초기화)가 영상당 일 2회로 제한됨
EVERYRIC_SERVER_ADMIN_API_KEY=

# ── 잡 처리 ─────────────────────────────────────────────────────
# GPU 1장 기준 1 권장 — 정렬+분리+멜로디가 GPU/RAM을 크게 쓴다
EVERYRIC_SERVER_MAX_CONCURRENT_JOBS=1
# 생성 허용 최대 오디오 길이(초). 0 = 무제한
EVERYRIC_SERVER_MAX_JOB_AUDIO_SEC=1800

# ── 데이터 ──────────────────────────────────────────────────────
# 절대 경로 권장 (미설정 시 WorkingDirectory 기준 ./everyric2.db)
DATABASE_URL=sqlite+aiosqlite:////opt/everyric2/everyric2.db
# 오디오 다운로드/임시 디렉터리 — 나중에 플랫폼과 캐시 공유할 때 이 경로를 바꾼다
EVERYRIC_AUDIO_TEMP_DIR=/tmp/everyric2

# ── 번역 (NVIDIA NIM 쓰는 경우) ─────────────────────────────────
EVERYRIC_TRANSLATE_ENGINE=nvidia
# NIM API 키 — 여기 넣거나, 리포 루트에 nvapi.txt 파일로 두거나 (env가 우선)
NVIDIA_API_KEY=

# ── 원격 GPU 워커 풀 (API 전용 서버 구성) ───────────────────────
# 서버 GPU가 본 서비스로 바쁘면: 워커 키를 설정하고 local_worker를 끄면
# 이 서버는 API+DB+큐만 맡고, 생성은 원격 워커(집 GPU PC 등)가 처리한다.
# 워커 실행: everyric2 worker --server <이 서버 URL> --key <워커 키>
# 상세는 deploy/DEPLOY.md의 워커 절 참고
# 워커 인증 키 (openssl rand -hex 32) — 미설정 시 워커 API 비활성
#EVERYRIC_SERVER_WORKER_KEY=
# false = 이 서버는 GPU 처리 안 함 (잡은 큐에 쌓여 워커가 가져감)
#EVERYRIC_SERVER_LOCAL_WORKER=true
# 워커 하트비트 끊김 판정 리스(초)
#EVERYRIC_SERVER_WORKER_LEASE_SEC=120

# ── yt-dlp 403 대응 (필요할 때만 주석 해제) ─────────────────────
# Netscape 형식 쿠키 파일 경로
#EVERYRIC_AUDIO_COOKIE_FILE=/opt/everyric2/youtube_cookies.txt
# 멀티 회선 서버에서 다운로드를 다른 공인 IP 회선으로 바인딩할 로컬 IP
#EVERYRIC_AUDIO_SOURCE_ADDRESS=
