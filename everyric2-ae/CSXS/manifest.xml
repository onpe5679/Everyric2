<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest Version="12.0"
  ExtensionBundleId="com.everyric.studio"
  ExtensionBundleName="Everyric Studio"
  ExtensionBundleVersion="2.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.everyric.studio.panel" Version="2.0.0"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[24.0,99.9]"/>
    </HostList>
    <LocaleList><Locale Code="All"/></LocaleList>
    <RequiredRuntimeList><RequiredRuntime Name="CSXS" Version="12.0"/></RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.everyric.studio.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./dist/jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Everyric Studio</Menu>
          <Geometry>
            <Size><Width>400</Width><Height>720</Height></Size>
            <MinSize><Width>300</Width><Height>480</Height></MinSize>
            <MaxSize><Width>900</Width><Height>1400</Height></MaxSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
