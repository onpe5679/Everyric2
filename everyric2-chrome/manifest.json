{
  "manifest_version": 3,
  "name": "Everyric - Synced Lyrics for YouTube",
  "version": "1.1.0",
  "minimum_chrome_version": "103",
  "description": "Display time-synced lyrics for any song on YouTube. Karaoke-style lyric highlighting with community-powered lyrics timing.",

  "permissions": ["storage", "notifications"],

  "host_permissions": [
    "https://lrclib.net/*",
    "https://api.everyric.com/*",
    "http://vocaro.wikidot.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [{
    "matches": [
      "https://www.youtube.com/*",
      "https://music.youtube.com/*"
    ],
    "js": ["src/content.ts"],
    "run_at": "document_idle"
  }],

  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },

  "externally_connectable": {
    "matches": ["https://everyric.com/*", "https://*.everyric.com/*"]
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Everyric 가사 패널 열기/닫기"
  },

  "web_accessible_resources": [{
    "resources": ["icons/*", "overlay.css"],
    "matches": ["https://www.youtube.com/*", "https://music.youtube.com/*"]
  }]
}
